{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [ "build", "${workspaceFolder}/InventarioApp.csproj", "/property:GenerateFullPaths=true", "/consoleloggerparameters:NoSummary;ForceNoAlign" ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [ "watch", "run", "--project", "${workspaceFolder}/InventarioApp.csproj" ],
            "problemMatcher": "$msCompile"
        }
    ]
}
