<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Inventario</title>

    <!-- Tailwind CSS (CDN) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Tabulator CSS -->
    <!-- <link rel="stylesheet" href="https://unpkg.com/tabulator-tables@6.2.1/dist/css/tabulator_tailwind.min.css"/> -->
    <link rel="stylesheet" href="https://unpkg.com/tabulator-tables@6.2.1/dist/css/tabulator.min.css"/>
    <!-- Font: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body { font-family: 'Inter', sans-serif; }
        /* Sidebar activo */
        .nav-link.active { background-color: #4338ca; color: #ffffff; }
        /* Alerta stock bajo en Tabulator */
        .stock-bajo { background-color: #fef2f2 !important; color: #991b1b !important; font-weight: 600; }
    </style>
</head>
<body class="bg-gray-100 text-gray-800">

@if (User.Identity?.IsAuthenticated == true)
{
    <!-- ────────── Layout con Sidebar ────────── -->
    <div class="flex min-h-screen">

        <!-- Sidebar -->
        <aside class="w-64 bg-indigo-900 text-white flex flex-col shadow-xl">
            <!-- Logo -->
            <div class="px-6 py-5 border-b border-indigo-800">
                <span class="text-xl font-bold tracking-tight">📦 Inventario</span>
                <p class="text-indigo-300 text-xs mt-1">Sistema de Control</p>
            </div>

            <!-- Menú de navegación -->
            <nav class="flex-1 px-4 py-6 space-y-1">
                <a href="/Home" class="nav-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-indigo-100 hover:bg-indigo-700 transition">
                    🏠 <span>Dashboard</span>
                </a>
                <a href="/Categorias" class="nav-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-indigo-100 hover:bg-indigo-700 transition">
                    🗂️ <span>Categorías</span>
                </a>
                <a href="/Productos" class="nav-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-indigo-100 hover:bg-indigo-700 transition">
                    📋 <span>Productos</span>
                </a>
                <a href="/Compras" class="nav-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-indigo-100 hover:bg-indigo-700 transition">
                    🛒 <span>Compras</span>
                </a>
                <a href="/Ventas" class="nav-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-indigo-100 hover:bg-indigo-700 transition">
                    💰 <span>POS / Ventas</span>
                </a>
            </nav>

            <!-- Usuario + Logout -->
            <div class="px-4 py-4 border-t border-indigo-800">
                <p class="text-indigo-300 text-xs">Sesión iniciada como</p>
                <p class="text-white text-sm font-medium">@User.Identity!.Name</p>
                <a href="/Login/Logout" class="mt-3 block text-center text-xs bg-indigo-700 hover:bg-red-600 text-white py-2 rounded-lg transition">
                    Cerrar sesión
                </a>
            </div>
        </aside>

        <!-- Contenido principal -->
        <main class="flex-1 flex flex-col overflow-auto">
            <!-- Topbar -->
            <header class="bg-white shadow-sm px-8 py-4 flex items-center justify-between">
                <h1 class="text-xl font-semibold text-gray-700">@ViewData["Title"]</h1>
                <span class="text-sm text-gray-400">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</span>
            </header>

            <!-- Alertas globales -->
            @if (TempData["Exito"] != null)
            {
                <div class="mx-8 mt-4 bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded">
                    ✅ @TempData["Exito"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="mx-8 mt-4 bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
                    ❌ @TempData["Error"]
                </div>
            }

            <div class="flex-1 p-8">
                @RenderBody()
            </div>
        </main>
    </div>
}
else
{
    <!-- Layout simple para Login -->
    @RenderBody()
}

<!-- jQuery -->
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<!-- Tabulator JS -->
<script src="https://unpkg.com/tabulator-tables@6.2.1/dist/js/tabulator.min.js"></script>

<!-- Marcar enlace activo en el sidebar -->
<script>
    $(function () {
        var path = window.location.pathname.split('/')[1];
        $('.nav-link').each(function () {
            var href = $(this).attr('href').replace('/', '');
            if (href === path || (path === '' && href === 'Home')) {
                $(this).addClass('active bg-indigo-700');
            }
        });
    });
</script>

@RenderSection("Scripts", required: false)
</body>
</html>
