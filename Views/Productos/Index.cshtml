@{
    ViewData["Title"] = "Productos";
    var categorias = ViewBag.Categorias as List<InventarioApp.Models.Categoria> ?? new();
}

<!-- Barra de acciones -->
<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 mb-6">
    <div class="flex items-center gap-3">
        <input id="busqueda" type="text" placeholder="🔍 Buscar producto..."
               class="border border-gray-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 w-64" />
        <button onclick="buscar()"
                class="bg-gray-200 hover:bg-gray-300 text-gray-700 text-sm px-4 py-2 rounded-lg transition">
            Buscar
        </button>
    </div>
    <button onclick="abrirModal()"
            class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition">
        + Nuevo Producto
    </button>
</div>

<!-- Alerta de stock bajo -->
<div id="alerta-stock" class="hidden bg-red-50 border-l-4 border-red-500 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">
    ⚠️ Hay productos con stock menor a 5 unidades (resaltados en rojo).
</div>

<!-- Tabla Tabulator -->
<div class="bg-white rounded-xl shadow p-4">
    <div id="tabla-productos"></div>
</div>

<!-- ══════════ Modal Crear / Editar ══════════ -->
<div id="modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg p-6">
        <h2 id="modal-titulo" class="text-lg font-semibold text-gray-800 mb-4">Nuevo Producto</h2>

        <input type="hidden" id="inp-id" value="0" />

        <div class="grid grid-cols-2 gap-4">
            <div class="col-span-2">
                <label class="label-form">Nombre *</label>
                <input id="inp-nombre" type="text" class="input-form" />
            </div>
            <div class="col-span-2">
                <label class="label-form">Descripción</label>
                <textarea id="inp-descripcion" rows="2" class="input-form"></textarea>
            </div>
            <div>
                <label class="label-form">Precio *</label>
                <input id="inp-precio" type="number" step="0.01" min="0" class="input-form" />
            </div>
            <div>
                <label class="label-form">Stock *</label>
                <input id="inp-stock" type="number" min="0" class="input-form" />
            </div>
            <div class="col-span-2">
                <label class="label-form">Categoría *</label>
                <select id="inp-categoria" class="input-form">
                    <option value="">-- Selecciona --</option>
                    @foreach (var cat in categorias)
                    {
                        <option value="@cat.Id">@cat.Nombre</option>
                    }
                </select>
            </div>
        </div>

        <p id="err-form" class="text-red-500 text-xs mt-3 hidden">Todos los campos marcados con * son obligatorios.</p>

        <div class="flex justify-end gap-3 mt-6">
            <button onclick="cerrarModal()"
                    class="px-4 py-2 text-sm rounded-lg border border-gray-300 hover:bg-gray-100 transition">
                Cancelar
            </button>
            <button onclick="guardar()"
                    class="px-4 py-2 text-sm rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white transition">
                Guardar
            </button>
        </div>
    </div>
</div>

<!-- Estilos inline para campos del formulario -->
<style>
    .label-form { display: block; font-size: .875rem; font-weight: 500; color: #374151; margin-bottom: .25rem; }
    .input-form  { width: 100%; border: 1px solid #d1d5db; border-radius: .5rem; padding: .5rem .75rem; font-size: .875rem; }
    .input-form:focus { outline: none; box-shadow: 0 0 0 2px #6366f1; border-color: transparent; }
</style>

@section Scripts {
<script>
// ── Tabulator ────────────────────────────────────────────────
var tabla = new Tabulator("#tabla-productos", {
    ajaxURL: "/Productos/ObtenerTodos",
    layout: "fitColumns",
    placeholder: "No hay productos",
    pagination: "local",
    paginationSize: 10,
    rowFormatter: function (row) {
        // Resaltar filas con stock bajo
        if (row.getData().stockBajo) row.getElement().classList.add("stock-bajo");
    },
    columns: [
        { title: "#",          field: "id",              width: 55, hozAlign: "center" },
        { title: "Nombre",     field: "nombre",           widthGrow: 2 },
        { title: "Categoría",  field: "categoriaNombre",  widthGrow: 1 },
        { title: "Precio",     field: "precio",           width: 100, hozAlign: "right",
          formatter: "money", formatterParams: { symbol: "$", precision: 2 } },
        { title: "Stock",      field: "stock",            width: 80,  hozAlign: "center",
          formatter: function(cell) {
              var v = cell.getValue();
              return v < 5
                ? `<span class="bg-red-100 text-red-700 font-bold px-2 py-0.5 rounded">${v} ⚠️</span>`
                : `<span class="bg-green-100 text-green-700 px-2 py-0.5 rounded">${v}</span>`;
          }
        },
        {
            title: "Acciones", hozAlign: "center", width: 170,
            formatter: function(cell) {
                var d = cell.getRow().getData();
                return `<div class="flex gap-2 justify-center">
                    <button onclick="editar(${d.id})" class="bg-yellow-400 hover:bg-yellow-500 text-white text-xs px-3 py-1 rounded-md">✏️ Editar</button>
                    <button onclick="eliminar(${d.id})" class="bg-red-500 hover:bg-red-600 text-white text-xs px-3 py-1 rounded-md">🗑 Eliminar</button>
                </div>`;
            }
        }
    ]
});

// Mostrar alerta si hay stock bajo
tabla.on("dataLoaded", function(data) {
    var hayBajo = data.some(p => p.stockBajo);
    hayBajo ? $("#alerta-stock").removeClass("hidden") : $("#alerta-stock").addClass("hidden");
});

// ── Búsqueda ─────────────────────────────────────────────────
function buscar() {
    tabla.setData("/Productos/ObtenerTodos", { busqueda: $("#busqueda").val() });
}
$("#busqueda").on("keypress", function(e) { if (e.which === 13) buscar(); });

// ── Modal ─────────────────────────────────────────────────────
function abrirModal() {
    $("#inp-id").val(0);
    $("#inp-nombre,#inp-descripcion,#inp-precio,#inp-stock").val("");
    $("#inp-categoria").val("");
    $("#modal-titulo").text("Nuevo Producto");
    $("#err-form").addClass("hidden");
    $("#modal").removeClass("hidden");
}

function cerrarModal() { $("#modal").addClass("hidden"); }

function editar(id) {
    $.get("/Productos/ObtenerPorId/" + id, function(p) {
        $("#inp-id").val(p.id);
        $("#inp-nombre").val(p.nombre);
        $("#inp-descripcion").val(p.descripcion);
        $("#inp-precio").val(p.precio);
        $("#inp-stock").val(p.stock);
        $("#inp-categoria").val(p.categoria_id);
        $("#modal-titulo").text("Editar Producto");
        $("#err-form").addClass("hidden");
        $("#modal").removeClass("hidden");
    });
}

// ── Guardar ──────────────────────────────────────────────────
function guardar() {
    var nombre    = $("#inp-nombre").val().trim();
    var precio    = parseFloat($("#inp-precio").val());
    var stock     = parseInt($("#inp-stock").val());
    var catId     = parseInt($("#inp-categoria").val());

    if (!nombre || isNaN(precio) || isNaN(stock) || isNaN(catId)) {
        $("#err-form").removeClass("hidden"); return;
    }
    $("#err-form").addClass("hidden");

    $.ajax({
        url: "/Productos/Guardar",
        method: "POST",
        contentType: "application/json",
        data: JSON.stringify({
            id: parseInt($("#inp-id").val()),
            nombre, descripcion: $("#inp-descripcion").val(),
            precio, stock, categoria_idd: catId
        }),
        success: function(res) {
            cerrarModal();
            tabla.setData();
            mostrarToast(res.mensaje, "exito");
        },
        error: function(xhr) { mostrarToast("Error: " + xhr.responseText, "error"); }
    });
}

// ── Eliminar ─────────────────────────────────────────────────
function eliminar(id) {
    if (!confirm("¿Eliminar este producto?")) return;
    $.ajax({
        url: "/Productos/Eliminar/" + id, method: "DELETE",
        success: function(res) { tabla.setData(); mostrarToast(res.mensaje, "exito"); },
        error:   function(xhr) { mostrarToast(xhr.responseJSON?.mensaje || "Error", "error"); }
    });
}

// ── Toast ────────────────────────────────────────────────────
function mostrarToast(msg, tipo) {
    var color = tipo === "exito" ? "bg-green-500" : "bg-red-500";
    var t = $(`<div class="fixed bottom-6 right-6 ${color} text-white px-5 py-3 rounded-xl shadow-lg text-sm z-50">${msg}</div>`);
    $("body").append(t);
    setTimeout(() => t.fadeOut(400, () => t.remove()), 3000);
}
</script>
}
