@model LoginViewModel
@{
    Layout = null;  // No usar el layout principal
    ViewData["Title"] = "Iniciar Sesión";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inventario – Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style> body { font-family: 'Inter', sans-serif; } </style>
</head>
<body class="bg-gradient-to-br from-indigo-900 via-indigo-800 to-purple-900 min-h-screen flex items-center justify-center">

<div class="w-full max-w-md px-6">
    <!-- Card -->
    <div class="bg-white rounded-2xl shadow-2xl p-8">
        <!-- Logo / encabezado -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-indigo-100 rounded-full mb-4">
                <span class="text-3xl">📦</span>
            </div>
            <h1 class="text-2xl font-bold text-gray-800">Sistema de Inventario</h1>
            <p class="text-gray-500 text-sm mt-1">Ingresa tus credenciales para continuar</p>
        </div>

        <!-- Errores de validación global -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="bg-red-50 border border-red-300 text-red-700 rounded-lg px-4 py-3 mb-6 text-sm">
                @Html.ValidationSummary(false)
            </div>
        }

        <!-- Formulario -->
        <form asp-action="Index" asp-controller="Login" method="post">
            @Html.AntiForgeryToken()

            <!-- Correo -->
            <div class="mb-5">
                <label asp-for="Correo" class="block text-sm font-medium text-gray-700 mb-1">
                    Correo electrónico
                </label>
                <input asp-for="Correo" type="email" placeholder="admin@demo.com"
                       class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" />
                <span asp-validation-for="Correo" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <!-- Contraseña -->
            <div class="mb-6">
                <label asp-for="Password" class="block text-sm font-medium text-gray-700 mb-1">
                    Contraseña
                </label>
                <input asp-for="Password" type="password" placeholder="••••••••"
                       class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" />
                <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <!-- Botón -->
            <button type="submit"
                    class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2.5 rounded-lg transition text-sm">
                Iniciar sesión
            </button>
        </form>

        <p class="text-center text-xs text-gray-400 mt-6">
            Demo: <strong>admin@demo.com</strong> / <strong>Admin123</strong>
        </p>
    </div>
</div>

</body>
</html>
