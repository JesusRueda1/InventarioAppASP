@{
    ViewData["Title"] = "POS – Punto de Venta";
}

<div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

    <!-- ── Panel izquierdo: buscador + carrito ── -->
    <div class="xl:col-span-2 space-y-5">

        <!-- Buscador de productos -->
        <div class="bg-white rounded-2xl shadow-lg p-5 card-hover">
            <label class="block text-sm font-semibold text-gray-700 mb-3 flex items-center gap-2">
                <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                Buscar producto por nombre
            </label>
            <div class="flex gap-3">
                <div class="relative flex-1">
                    <input id="buscar-prod" type="text" placeholder="Escribe el nombre del producto..."
                           class="w-full border-2 border-gray-200 rounded-xl pl-10 pr-4 py-3 text-sm focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100 transition-all" />
                    <svg class="w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </div>
                <button onclick="buscarProducto()"
                        class="btn-action bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white text-sm font-medium px-6 py-3 rounded-xl transition shadow-lg">
                    Buscar
                </button>
            </div>

            <!-- Resultados de busqueda -->
            <div id="resultados-busqueda" class="mt-4 hidden">
                <p class="text-xs text-gray-500 mb-3 flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    Haz clic en un producto para agregarlo al carrito
                </p>
                <div id="lista-resultados" class="grid grid-cols-2 sm:grid-cols-3 gap-3"></div>
            </div>
        </div>

        <!-- Carrito / detalle de venta -->
        <div class="bg-white rounded-2xl shadow-lg p-5 card-hover">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-bold text-gray-800 flex items-center gap-2">
                    <span class="w-8 h-8 bg-indigo-100 rounded-lg flex items-center justify-center">
                        <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
                        </svg>
                    </span>
                    Carrito de Venta
                </h2>
                <span class="text-xs text-gray-400" id="count-carrito">0 items</span>
            </div>
            <div class="overflow-x-auto rounded-xl border border-gray-200">
                <table class="w-full text-sm">
                    <thead class="bg-gradient-to-r from-slate-700 to-slate-800 text-white">
                        <tr>
                            <th class="px-4 py-3 text-left font-semibold text-xs uppercase tracking-wide">Producto</th>
                            <th class="px-4 py-3 text-center font-semibold text-xs uppercase tracking-wide w-32">Cantidad</th>
                            <th class="px-4 py-3 text-right font-semibold text-xs uppercase tracking-wide">Precio</th>
                            <th class="px-4 py-3 text-right font-semibold text-xs uppercase tracking-wide">Subtotal</th>
                            <th class="px-4 py-3 w-10"></th>
                        </tr>
                    </thead>
                    <tbody id="carrito-body" class="divide-y divide-gray-100">
                        <tr id="carrito-empty">
                            <td colspan="5" class="text-center py-10">
                                <svg class="w-12 h-12 mx-auto text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
                                </svg>
                                <p class="text-gray-400 text-sm">El carrito esta vacio</p>
                                <p class="text-gray-300 text-xs mt-1">Busca un producto arriba para comenzar</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ── Panel derecho: resumen + historial ── -->
    <div class="space-y-5">

        <!-- Resumen de venta -->
        <div class="bg-gradient-to-br from-indigo-900 via-purple-900 to-indigo-800 text-white rounded-2xl shadow-2xl p-6 card-hover relative overflow-hidden">
            <div class="absolute top-0 right-0 w-40 h-40 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
            <div class="absolute bottom-0 left-0 w-32 h-32 bg-white/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>
            
            <div class="relative">
                <p class="text-indigo-200 text-sm font-medium mb-2">Total a cobrar</p>
                <p class="text-5xl font-bold mb-6 tracking-tight" id="total-venta">$0.00</p>
                
                <button onclick="procesarVenta()"
                        class="w-full btn-action bg-gradient-to-r from-emerald-400 to-teal-400 hover:from-emerald-500 hover:to-teal-500 text-emerald-900 font-bold py-4 rounded-xl transition text-base shadow-lg flex items-center justify-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    Cobrar Venta
                </button>
                <button onclick="limpiarCarrito()"
                        class="mt-3 w-full bg-white/10 hover:bg-white/20 text-white/80 hover:text-white py-2.5 rounded-xl transition text-sm font-medium flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                    Limpiar carrito
                </button>
            </div>
        </div>

        <!-- Historial de ventas -->
        <div class="bg-white rounded-2xl shadow-lg p-5 card-hover">
            <div class="flex items-center gap-3 mb-4">
                <span class="w-8 h-8 bg-emerald-100 rounded-lg flex items-center justify-center">
                    <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                    </svg>
                </span>
                <h3 class="text-base font-bold text-gray-800">Ultimas Ventas</h3>
            </div>
            <div id="tabla-ventas"></div>
        </div>
    </div>
</div>

<!-- Modal comprobante -->
<div id="modal-comprobante" class="modal-overlay fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50">
    <div class="modal-content bg-white rounded-2xl shadow-2xl w-full max-w-sm p-8 mx-4 text-center relative overflow-hidden">
        <!-- Confetti background effect -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none">
            <div class="absolute top-4 left-4 w-3 h-3 bg-emerald-400 rounded-full animate-bounce" style="animation-delay: 0.1s"></div>
            <div class="absolute top-8 right-8 w-2 h-2 bg-purple-400 rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
            <div class="absolute top-12 left-12 w-2 h-2 bg-yellow-400 rounded-full animate-bounce" style="animation-delay: 0.3s"></div>
            <div class="absolute top-6 right-16 w-3 h-3 bg-indigo-400 rounded-full animate-bounce" style="animation-delay: 0.4s"></div>
        </div>
        
        <div class="relative">
            <div class="w-20 h-20 bg-gradient-to-br from-emerald-400 to-teal-500 rounded-full mx-auto mb-5 flex items-center justify-center shadow-lg">
                <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
            </div>
            <h3 class="text-2xl font-bold text-gray-800 mb-2">Venta Exitosa!</h3>
            <p id="comp-total" class="text-4xl font-bold text-emerald-600 mb-4"></p>
            <p class="text-sm text-gray-500 bg-gray-100 rounded-xl py-2 px-4 inline-block" id="comp-info"></p>
            <div class="mt-6 grid grid-cols-2 gap-2" id="comp-actions">
                <!-- Se inyecta por JS -->
            </div>
            <button onclick="cerrarComprobante()"
                    class="mt-3 w-full btn-action bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-2.5 rounded-xl transition shadow-sm">
                Nueva Venta
            </button>
        </div>
    </div>
</div>

@section Scripts {
<script>
var carrito = [];   // { productoId, nombre, cantidad, precioVenta, stock }

// ── Tabla historial ventas ───────────────────────────────────
var tablaV = new Tabulator("#tabla-ventas", {
    ajaxURL: "/Ventas/ObtenerTodas",
    layout: "fitColumns",
    pagination: "local",
    paginationSize: 6,
    placeholder: "<div class='text-center py-6'><svg class='w-8 h-8 mx-auto text-gray-300 mb-2' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2'/></svg><p class='text-gray-400 text-xs'>Sin ventas</p></div>",
    columns: [
        { title: "#", field: "id", width: 50, hozAlign: "center",
          formatter: function(cell) {
              return `<span class="inline-flex items-center justify-center w-6 h-6 rounded bg-emerald-100 text-emerald-700 font-semibold text-xs">${cell.getValue()}</span>`;
          }
        },
        { title: "Fecha", field: "fecha", widthGrow: 1,
          formatter: function(cell) {
              return `<span class="text-gray-600 text-xs">${cell.getValue()}</span>`;
          }
        },
        { title: "Total", field: "total", width: 90, hozAlign: "right",
          formatter: function(cell) {
              return `<span class="font-bold text-emerald-600">$${parseFloat(cell.getValue()).toFixed(2)}</span>`;
          }
        },
        { title: "", hozAlign: "center", width: 80,
          formatter: function(cell) {
              var id = cell.getRow().getData().id;
              return `<div class="flex gap-1 justify-center">
                  <a href="/Ventas/Ticket/${id}" target="_blank" title="Imprimir Ticket" class="w-7 h-7 rounded bg-indigo-50 text-indigo-600 flex items-center justify-center hover:bg-indigo-600 hover:text-white transition cursor-pointer">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
                  </a>
                  <a href="/Ventas/Factura/${id}" target="_blank" title="Factura A4" class="w-7 h-7 rounded bg-purple-50 text-purple-600 flex items-center justify-center hover:bg-purple-600 hover:text-white transition cursor-pointer">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                  </a>
              </div>`;
          }
        }
    ]
});

// ── Buscar producto ──────────────────────────────────────────
function buscarProducto() {
    var q = $("#buscar-prod").val().trim();

    if (!q) {
        Toast.warning('Campo vacio', 'Ingresa un termino de busqueda');
        return;
    }

    if (!q) return;
    $.get("/Ventas/BuscarProducto", { q }, function(data) {
        var lista = $("#lista-resultados").empty();
        if (data.length === 0) {
            lista.html(`<div class="col-span-full text-center py-4">
                <svg class="w-8 h-8 mx-auto text-gray-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <p class="text-gray-400 text-sm">No se encontraron productos</p>
            </div>`);
        } else {
            data.forEach(function(p) {
                var stockClass = p.stock < 5 ? 'text-red-500' : 'text-emerald-500';
                lista.append(`<button onclick='agregarAlCarrito(${JSON.stringify(p)})'
                    class="text-left bg-gradient-to-br from-indigo-50 to-purple-50 hover:from-indigo-100 hover:to-purple-100 border-2 border-indigo-200 hover:border-indigo-400 rounded-xl p-4 transition-all hover:shadow-md group">
                    <p class="font-semibold text-indigo-800 group-hover:text-indigo-900 mb-1">${p.nombre}</p>
                    <div class="flex items-center justify-between">
                        <span class="text-lg font-bold text-emerald-600">$${parseFloat(p.precio).toFixed(2)}</span>
                        <span class="text-xs ${stockClass} font-medium">Stock: ${p.stock}</span>
                    </div>
                </button>`);
            });
        }
        $("#resultados-busqueda").removeClass("hidden");
    });
}
$("#buscar-prod").on("keypress", function(e) { if (e.which === 13) buscarProducto(); });

// ── Agregar al carrito ───────────────────────────────────────
function agregarAlCarrito(p) {
    var existente = carrito.find(i => i.productoId === p.id);
    if (existente) {
        if (existente.cantidad >= existente.stock) {
            Toast.error('Sin stock', 'No hay mas stock disponible para este producto');
            return;
        }
        existente.cantidad++;
        Toast.info('Actualizado', 'Se aumento la cantidad del producto');
    } else {
        carrito.push({ productoId: p.id, nombre: p.nombre, cantidad: 1, precioVenta: p.precio, stock: p.stock });
        Toast.success('Agregado', p.nombre + ' se agrego al carrito');
    }
    renderCarrito();
    $("#resultados-busqueda").addClass("hidden");
    $("#buscar-prod").val("").focus();
}

// ── Renderizar carrito ───────────────────────────────────────
function renderCarrito() {
    var body = $("#carrito-body").empty();
    if (carrito.length === 0) {
        body.html(`<tr id="carrito-empty">
            <td colspan="5" class="text-center py-10">
                <svg class="w-12 h-12 mx-auto text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
                </svg>
                <p class="text-gray-400 text-sm">El carrito esta vacio</p>
                <p class="text-gray-300 text-xs mt-1">Busca un producto arriba para comenzar</p>
            </td>
        </tr>`);
        $("#total-venta").text("$0.00"); 
        $("#count-carrito").text("0 items");
        return;
    }
    var total = 0;
    var totalItems = 0;
    carrito.forEach(function(item, i) {
        var sub = item.cantidad * item.precioVenta;
        total += sub;
        totalItems += item.cantidad;
        body.append(`<tr class="hover:bg-gray-50 transition">
            <td class="px-4 py-3">
                <span class="font-medium text-gray-800">${item.nombre}</span>
                <span class="block text-xs text-gray-400">Stock disponible: ${item.stock}</span>
            </td>
            <td class="px-4 py-3 text-center">
                <div class="flex items-center justify-center gap-2">
                    <button onclick="cambiarCantidad(${i}, -1)" class="w-8 h-8 bg-gray-100 hover:bg-gray-200 rounded-lg flex items-center justify-center transition text-gray-600 hover:text-gray-800 font-bold">-</button>
                    <span class="w-10 text-center font-semibold text-gray-800">${item.cantidad}</span>
                    <button onclick="cambiarCantidad(${i}, 1)" class="w-8 h-8 bg-gray-100 hover:bg-gray-200 rounded-lg flex items-center justify-center transition text-gray-600 hover:text-gray-800 font-bold">+</button>
                </div>
            </td>
            <td class="px-4 py-3 text-right text-gray-600">$${parseFloat(item.precioVenta).toFixed(2)}</td>
            <td class="px-4 py-3 text-right font-bold text-emerald-600">$${sub.toFixed(2)}</td>
            <td class="px-4 py-3 text-center">
                <button onclick="quitarItem(${i})" class="w-8 h-8 rounded-full bg-red-100 hover:bg-red-200 text-red-500 hover:text-red-700 flex items-center justify-center transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </td>
        </tr>`);
    });
    $("#total-venta").text("$" + total.toFixed(2));
    $("#count-carrito").text(totalItems + " item(s)");
}

function cambiarCantidad(i, delta) {
    carrito[i].cantidad += delta;
    if (carrito[i].cantidad <= 0) {
        carrito.splice(i, 1);
    } else if (carrito[i].cantidad > carrito[i].stock) { 
        carrito[i].cantidad = carrito[i].stock;
        Toast.warning('Limite alcanzado', 'No hay mas stock disponible');
    }
    renderCarrito();
}

function quitarItem(i) { 
    var nombre = carrito[i].nombre;
    carrito.splice(i, 1); 
    renderCarrito(); 
    Toast.info('Eliminado', nombre + ' se quito del carrito');
}

function limpiarCarrito() { 
    if (carrito.length === 0) return;
    Swal2.confirm({
        title: 'Limpiar carrito?',
        text: 'Se eliminaran todos los productos del carrito',
        icon: 'warning'
    }).then((result) => {
        if (result.isConfirmed) {
            carrito = []; 
            renderCarrito(); 
            Toast.info('Carrito limpio', 'Se eliminaron todos los productos');
        }
    });
}

// ── Procesar venta ───────────────────────────────────────────
function procesarVenta() {
    if (carrito.length === 0) { 
        Swal2.error({ title: 'Carrito vacio', text: 'Agrega productos al carrito antes de cobrar' });
        return; 
    }

    var total = carrito.reduce((sum, item) => sum + (item.cantidad * item.precioVenta), 0);
    
    Swal.fire({
        title: 'Confirmar Venta',
        html: `<div class="text-center">
            <p class="text-gray-600 mb-2">Total de la venta:</p>
            <p class="text-4xl font-bold text-emerald-600">$${total.toFixed(2)}</p>
            <p class="text-xs text-gray-400 mt-2">${carrito.length} producto(s) en el carrito</p>
        </div>`,
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#10b981',
        cancelButtonColor: '#94a3b8',
        confirmButtonText: 'Cobrar',
        cancelButtonText: 'Cancelar',
        reverseButtons: true,
        showClass: {
            popup: 'animate__animated animate__zoomIn animate__faster'
        }
    }).then((result) => {
        if (result.isConfirmed) {
            var detalles = carrito.map(i => ({ productoId: i.productoId, cantidad: i.cantidad, precioVenta: i.precioVenta }));
            $.ajax({
                url: "/Ventas/Registrar", method: "POST", contentType: "application/json",
                data: JSON.stringify({ detalles }),
                success: function(res) {
                    $("#comp-total").text("$" + parseFloat(res.total).toFixed(2));
                    $("#comp-info").text("Venta #" + res.id + " registrada correctamente");

                    $("#comp-actions").html(`
                        <a href="/Ventas/Ticket/${res.id}" target="_blank" class="flex flex-col items-center justify-center p-3 bg-indigo-50 hover:bg-indigo-100 text-indigo-700 rounded-xl transition border border-indigo-100">
                            <svg class="w-5 h-5 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
                            <span class="text-xs font-bold">Ticket POS</span>
                        </a>
                        <a href="/Ventas/Factura/${res.id}" target="_blank" class="flex flex-col items-center justify-center p-3 bg-purple-50 hover:bg-purple-100 text-purple-700 rounded-xl transition border border-purple-100">
                            <svg class="w-5 h-5 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                            <span class="text-xs font-bold">Factura A4</span>
                        </a>
                    `);

                    $("#modal-comprobante").addClass("active");
                    carrito = []; 
                    renderCarrito();
                },
                error: function(xhr) { 
                    Swal2.error({ title: 'Error', text: xhr.responseJSON?.mensaje || "Error al registrar la venta" }); 
                }
            });
        }
    });
}

function cerrarComprobante() {
    $("#modal-comprobante").removeClass("active");
    tablaV.setData();
}

// Modal handlers
$(document).on('keydown', function(e) {
    if (e.key === 'Escape' && $("#modal-comprobante").hasClass("active")) cerrarComprobante();
});
$("#modal-comprobante").on('click', function(e) {
    if (e.target === this) cerrarComprobante();
});
</script>
