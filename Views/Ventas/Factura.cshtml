@model InventarioApp.Models.Transaccion
@{
    Layout = null; 
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <title>Factura de Venta #@Model.Id</title>
    <!-- Tailwind CSS (CDN) para diseño rapido de A4 -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @@page { size: A4; margin: 20mm; }
        @@media print {
            body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
            .no-print { display: none !important; }
        }
    </style>
</head>
<body class="bg-gray-100 font-sans text-gray-800 p-8">

    <div class="max-w-4xl mx-auto bg-white p-10 rounded-lg shadow-xl print:shadow-none print:p-0">
        <!-- Header Botones -->
        <div class="flex justify-between items-center mb-8 border-b pb-4 no-print">
            <h2 class="text-2xl font-bold text-gray-800">Vista Previa de Factura</h2>
            <button onclick="window.print()" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded shadow">
                🖨️ Imprimir A4
            </button>
        </div>

        <!-- Encabezado de la factura -->
        <div class="flex justify-between items-start mb-8 border-b pb-4">
            <div>
                <h1 class="text-4xl font-black text-indigo-700 uppercase tracking-tight">FACTURA</h1>
                <p class="text-xl text-gray-500 font-medium">Nº @Model.Id.ToString("D5")</p>
            </div>
            <div class="text-right text-sm">
                <p class="font-bold text-gray-800 text-lg">MI EMPRESA S.A.S.</p>
                <p class="text-gray-600">NIT: 900.123.456-7</p>
                <p class="text-gray-600">Calle Principal #123, Ciudad</p>
                <p class="text-gray-600">Tel: +57 300 000 0000</p>
            </div>
        </div>

        <!-- Info Cliente / Venta -->
        <div class="flex justify-between items-end mb-8 bg-gray-50 p-4 rounded-lg">
            <div class="text-sm">
                <p class="font-bold text-gray-700 uppercase">Facturar a:</p>
                <p class="text-gray-600 mt-1">Consumidor Final</p>
            </div>
            <div class="text-sm text-right space-y-1">
                <p><span class="font-semibold text-gray-700">Fecha de Emisión:</span> @Model.Fecha.ToString("dd MMMM, yyyy")</p>
                <p><span class="font-semibold text-gray-700">Estado de Pago:</span> 
                    <span class="inline-block bg-green-100 text-green-800 px-2 py-0.5 rounded font-bold uppercase">@Model.EstadoPago</span>
                </p>
            </div>
        </div>

        <!-- Tabla -->
        <table class="w-full text-left mb-8 border-collapse">
            <thead>
                <tr class="bg-indigo-600 text-white">
                    <th class="py-3 px-4 rounded-tl-lg font-semibold uppercase text-xs">Cant</th>
                    <th class="py-3 px-4 font-semibold uppercase text-xs">Descripción</th>
                    <th class="py-3 px-4 font-semibold uppercase text-xs text-right">IVA %</th>
                    <th class="py-3 px-4 font-semibold uppercase text-xs text-right">Precio Unit.</th>
                    <th class="py-3 px-4 rounded-tr-lg font-semibold uppercase text-xs text-right">Subtotal</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                @foreach (var p in Model.DetallesVenta)
                {
                    decimal subtotalLinea = p.Cantidad * p.PrecioVenta;
                    <tr class="text-sm">
                        <td class="py-4 px-4 font-medium text-gray-900 border-l border-gray-200">@p.Cantidad</td>
                        <td class="py-4 px-4 text-gray-700">@p.Producto?.Nombre</td>
                        <td class="py-4 px-4 text-gray-600 text-right">@p.PorcentajeImpuesto%</td>
                        <td class="py-4 px-4 text-gray-600 text-right">$@p.PrecioVenta.ToString("N2")</td>
                        <td class="py-4 px-4 font-bold text-gray-800 border-r border-gray-200 text-right">
                            $@subtotalLinea.ToString("N2")
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Totales -->
        <div class="flex justify-end mt-4">
            <div class="w-1/2">
                <div class="flex justify-between py-2 text-sm border-b">
                    <span class="font-semibold text-gray-600">SUBTOTAL</span>
                    <span class="text-gray-800">$@Model.Subtotal.ToString("N2")</span>
                </div>
                <div class="flex justify-between py-2 text-sm border-b">
                    <span class="font-semibold text-gray-600">TOTAL IVA</span>
                    <span class="text-gray-800">$@Model.TotalImpuesto.ToString("N2")</span>
                </div>
                <div class="flex justify-between py-3 text-lg border-b-2 border-gray-800">
                    <span class="font-black text-gray-800 uppercase">Total a Pagar</span>
                    <span class="font-black text-indigo-700">$@Model.Total.ToString("N2")</span>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="mt-12 pt-8 border-t border-gray-200 text-center">
            <p class="text-xs text-gray-500 font-medium">Formato generado por software de ERP. Esta es una representación impresa de la factura electrónica.</p>
        </div>
    </div>
</body>
</html>
