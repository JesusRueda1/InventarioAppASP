@model List<Rol>
@{
    ViewData["Title"] = "Roles y Permisos";
}

<div class="fade-in-up">
    <!-- Header -->
    <div class="bg-white rounded-2xl shadow-sm p-6 mb-6">
        <h2 class="text-2xl font-bold text-gray-800">🛡️ Roles y Permisos</h2>
        <p class="text-gray-500 text-sm mt-1">Configura qué puede hacer cada rol en el sistema</p>
    </div>

    <!-- Cards de roles -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
        @foreach (var rol in Model)
        {
            <div class="card-hover bg-white rounded-2xl shadow-sm p-6 border border-gray-100">

                <!-- Cabecera del rol -->
                <div class="flex items-start justify-between mb-4">
                    <div>
                        <h3 class="text-lg font-bold text-gray-800">@rol.Nombre</h3>
                        @if (!string.IsNullOrEmpty(rol.Descripcion))
                        {
                            <p class="text-gray-400 text-xs mt-0.5">@rol.Descripcion</p>
                        }
                    </div>
                    <span class="bg-indigo-100 text-indigo-700 text-xs font-bold px-2.5 py-1 rounded-full">
                        @rol.Usuarios.Count usuario@(rol.Usuarios.Count != 1 ? "s" : "")
                    </span>
                </div>

                <!-- Lista de permisos -->
                <div class="space-y-1 mb-5 max-h-52 overflow-y-auto pr-1">
                    @{
                        var permisos = rol.RolPermisos
                            .Where(rp => rp.Permiso != null)
                            .Select(rp => rp.Permiso!.Nombre)
                            .OrderBy(n => n)
                            .ToList();
                    }
                    @if (permisos.Any())
                    {
                        @foreach (var p in permisos)
                        {
                            <div class="flex items-center gap-2 text-sm text-gray-600">
                                <span class="text-green-500 text-xs">✔</span>
                                <span class="font-mono text-xs bg-gray-50 px-2 py-0.5 rounded-md">@p</span>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-gray-300 text-sm italic">Sin permisos asignados</p>
                    }
                </div>

                <!-- Botón editar -->
                @if (User.Can("roles.editar"))
                {
                    <a href="/Roles/Edit/@rol.Id"
                       class="btn-action block text-center bg-indigo-50 hover:bg-indigo-100 text-indigo-700 py-2 rounded-xl text-sm font-semibold transition">
                        ✏️ Editar Permisos
                    </a>
                }
            </div>
        }
    </div>
</div>
