@{
    ViewData["Title"] = "Dashboard";
}

<!-- Tarjetas de resumen -->
<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">

    <div class="bg-white rounded-xl shadow p-6 flex items-center gap-4">
        <div class="w-12 h-12 bg-indigo-100 rounded-full flex items-center justify-center text-2xl">📋</div>
        <div>
            <p class="text-sm text-gray-500">Total Productos</p>
            <p class="text-3xl font-bold text-indigo-700">@ViewBag.TotalProductos</p>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow p-6 flex items-center gap-4">
        <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center text-2xl">🗂️</div>
        <div>
            <p class="text-sm text-gray-500">Categorías</p>
            <p class="text-3xl font-bold text-purple-700">@ViewBag.TotalCategorias</p>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow p-6 flex items-center gap-4 @(ViewBag.StockBajo > 0 ? "border-2 border-red-400" : "")">
        <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center text-2xl">⚠️</div>
        <div>
            <p class="text-sm text-gray-500">Stock Bajo (&lt;5)</p>
            <p class="text-3xl font-bold text-red-600">@ViewBag.StockBajo</p>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow p-6 flex items-center gap-4">
        <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center text-2xl">💰</div>
        <div>
            <p class="text-sm text-gray-500">Ventas Realizadas</p>
            <p class="text-3xl font-bold text-green-700">@ViewBag.TotalVentas</p>
        </div>
    </div>

</div>

<!-- Alerta general de stock bajo -->
@if (ViewBag.StockBajo > 0)
{
    <div class="bg-red-50 border-l-4 border-red-500 text-red-800 px-6 py-4 rounded-lg mb-6 flex items-center gap-3">
        <span class="text-2xl">🚨</span>
        <div>
            <p class="font-semibold">Atención: stock bajo en @ViewBag.StockBajo producto(s)</p>
            <a href="/Productos" class="text-sm underline text-red-600">Ver productos con stock bajo →</a>
        </div>
    </div>
}

<!-- Accesos rápidos -->
<div class="bg-white rounded-xl shadow p-6">
    <h2 class="text-lg font-semibold text-gray-700 mb-4">Accesos rápidos</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <a href="/Productos" class="flex flex-col items-center gap-2 bg-indigo-50 hover:bg-indigo-100 rounded-xl p-4 transition">
            <span class="text-3xl">📋</span>
            <span class="text-sm font-medium text-indigo-700">Productos</span>
        </a>
        <a href="/Categorias" class="flex flex-col items-center gap-2 bg-purple-50 hover:bg-purple-100 rounded-xl p-4 transition">
            <span class="text-3xl">🗂️</span>
            <span class="text-sm font-medium text-purple-700">Categorías</span>
        </a>
        <a href="/Compras" class="flex flex-col items-center gap-2 bg-yellow-50 hover:bg-yellow-100 rounded-xl p-4 transition">
            <span class="text-3xl">🛒</span>
            <span class="text-sm font-medium text-yellow-700">Nueva Compra</span>
        </a>
        <a href="/Ventas" class="flex flex-col items-center gap-2 bg-green-50 hover:bg-green-100 rounded-xl p-4 transition">
            <span class="text-3xl">💰</span>
            <span class="text-sm font-medium text-green-700">Nueva Venta</span>
        </a>
    </div>
</div>
