@{
    ViewData["Title"] = "Acceso Denegado";
}

<div class="min-h-screen bg-gray-100 flex items-center justify-center p-6 fade-in-up">
    <div class="bg-white rounded-3xl shadow-lg p-12 max-w-lg w-full text-center">

        <!-- Ícono animado -->
        <div class="text-8xl mb-6 animate__animated animate__shakeX">🚫</div>

        <h1 class="text-3xl font-bold text-gray-800 mb-3">Acceso Denegado</h1>
        <p class="text-gray-500 mb-2">No tienes permiso para acceder a esta sección.</p>
        <p class="text-gray-400 text-sm mb-8">
            Si crees que esto es un error, contacta con el administrador del sistema.
        </p>

        <!-- Info del usuario -->
        <div class="bg-gray-50 rounded-2xl p-4 mb-8 text-sm text-left">
            <p class="text-gray-500">
                <span class="font-semibold text-gray-700">Usuario:</span>
                @User.Identity?.Name
            </p>
            <p class="text-gray-500 mt-1">
                <span class="font-semibold text-gray-700">Rol:</span>
                @User.RoleName()
            </p>
        </div>

        <div class="flex gap-3 justify-center">
            <a href="/Home"
               class="btn-action bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-xl font-semibold transition">
                🏠 Ir al Dashboard
            </a>
            <a href="/Login/Logout"
               class="btn-action bg-gray-100 hover:bg-gray-200 text-gray-600 px-6 py-2.5 rounded-xl font-semibold transition">
                Cerrar Sesión
            </a>
        </div>
    </div>
</div>
