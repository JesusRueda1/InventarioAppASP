@model IEnumerable<InventarioApp.Models.AuditoriaLog>
@{
    ViewData["Title"] = "Auditoría del Sistema";
}

<div class="mb-6 flex justify-between items-center bg-white p-5 rounded-xl shadow-sm border border-gray-100">
    <div>
        <h2 class="text-2xl font-bold tracking-tight text-gray-800">🕵️‍♀️ Auditoría del Sistema</h2>
        <p class="text-gray-500 text-sm mt-1">Traza de operaciones y modificaciones globales ERP</p>
    </div>
    
    <form method="get" class="flex gap-3">
        <input type="date" name="fechaFiltro" value="@ViewBag.FechaFiltro" class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-700 outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500">
        <button type="submit" class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg transition-colors">
            Filtrar
        </button>
        <a href="/Auditoria" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Limpiar</a>
    </form>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm text-left whitespace-nowrap">
            <thead class="text-xs text-gray-500 bg-gray-50 uppercase border-b border-gray-200">
                <tr>
                    <th scope="col" class="px-6 py-4 font-semibold">Fecha/Hora</th>
                    <th scope="col" class="px-6 py-4 font-semibold">Usuario</th>
                    <th scope="col" class="px-6 py-4 font-semibold">Módulo</th>
                    <th scope="col" class="px-6 py-4 font-semibold">Acción de Sistema</th>
                    <th scope="col" class="px-6 py-4 font-semibold w-full">Detalles y Rastro</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 text-gray-600">
                @if(!Model.Any())
                {
                    <tr>
                         <td colspan="5" class="px-6 py-10 text-center text-gray-500">
                             No se encontraron trazas de auditoría en la fecha seleccionada.
                         </td>
                    </tr>
                }
                @foreach (var log in Model)
                {
                    <tr class="hover:bg-indigo-50/30 transition-colors">
                        <td class="px-6 py-4">
                            <div class="font-medium text-gray-800">@log.Fecha.ToString("dd MMM yyyy")</div>
                            <div class="text-xs text-gray-400">@log.Fecha.ToString("HH:mm:ss")</div>
                        </td>
                        <td class="px-6 py-4 font-medium text-indigo-600">
                            @(log.Usuario?.Nombre ?? "Sistema/Desconocido")
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                                @log.Modulo
                            </span>
                        </td>
                        <td class="px-6 py-4 font-mono text-xs">
                            @log.Accion
                        </td>
                        <td class="px-6 py-4 max-w-md truncate" title="@log.Detalles">
                            @log.Detalles
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
